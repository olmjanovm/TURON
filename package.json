{
  "name": "turon-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade TWA Food Delivery Platform",
  "scripts": {
    "dev:backend": "pnpm --filter @turon/backend dev",
    "dev:miniapp": "pnpm --filter @turon/miniapp dev",
    "db:generate": "pnpm --filter @turon/backend prisma:generate",
    "db:migrate": "pnpm --filter @turon/backend prisma:migrate",
    "db:seed": "pnpm --filter @turon/backend prisma:seed",
    "db:studio": "pnpm --filter @turon/backend prisma:studio",
    "build": "pnpm --filter \"@turon/*\" build",
    "install:all": "pnpm install",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "rimraf": "^5.0.0"
  }
}
