# =============================================================================
# TURON Platform — Environment Variables Reference
# Copy this file to .env and fill in the real values.
# NEVER commit .env with real credentials to git.
# =============================================================================

# ── Backend (Fastify API) ────────────────────────────────────────────────────

# Supabase pgBouncer pooler URL (used by Prisma at runtime)
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&connect_timeout=60&sslmode=require"

# Direct Supabase URL (used by migration scripts — optional but recommended)
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Telegram Bot token from @BotFather
BOT_TOKEN="1234567890:YOUR_BOT_TOKEN_FROM_BOTFATHER"

# Set to true to run the bot inside the API process
RUN_TELEGRAM_BOT=true

# JSON Web Token secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# URL where the Mini App is hosted (no trailing slash)
WEB_APP_URL="https://your-miniapp.vercel.app"

NODE_ENV="production"
PORT=3000
API_HOST="0.0.0.0"

# Allowed CORS origin for the API
CORS_ORIGIN="https://your-miniapp.vercel.app"

# ── Frontend (Vite / React Mini App) ─────────────────────────────────────────
# Vite reads env from the repo root (envDir: '../../' in vite.config.ts).
# For production builds use .env.production at the repo root.

# Base URL of the backend API (no trailing slash)
VITE_API_URL="https://your-api-domain.com"

# Telegram bot handle (without @) — used for deep-links in the Mini App
VITE_TELEGRAM_BOT_NAME="YourBotName"

# Maps provider: "yandex" or "none"
VITE_MAPS_PROVIDER="yandex"

# Yandex Maps JavaScript API key
VITE_MAP_API_KEY="your-yandex-maps-api-key-here"

# UI language for Yandex Maps
VITE_MAP_LANGUAGE="uz_UZ"
